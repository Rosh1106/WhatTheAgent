{
  "name": "whattheagent",
  "version": "0.1.0",
  "description": "Local-first capability discovery and governance CLI for AI agent workspaces.",
  "type": "module",
  "license": "MIT",
  "author": "Rosh1106",
  "homepage": "https://github.com/Rosh1106/WhatTheAgent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rosh1106/WhatTheAgent.git"
  },
  "bugs": {
    "url": "https://github.com/Rosh1106/WhatTheAgent/issues"
  },
  "keywords": [
    "ai-agent",
    "agent-security",
    "mcp",
    "claude",
    "codex",
    "cursor",
    "openclaw",
    "hermes",
    "security",
    "cli"
  ],
  "bin": {
    "whattheagent": "./dist/cli.js",
    "wta": "./dist/cli.js"
  },
  "files": [
    "dist",
    "examples",
    "readme",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "scan:example": "tsx src/cli.ts scan examples/risky-agent",
    "graph:example": "tsx src/cli.ts graph examples/risky-agent",
    "understand:example": "tsx src/cli.ts understand examples/risky-agent",
    "plan:example": "tsx src/cli.ts plan examples/risky-agent --for-codex",
    "probe:example": "tsx src/cli.ts probe examples/risky-agent",
    "instructions:example": "tsx src/cli.ts instructions --for-claude",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepack": "npm run build",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
